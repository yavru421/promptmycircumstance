@page "/"
@using PromptMyCircumstance.Models
@using PromptMyCircumstance.Services
@inject BalancedScoringEngine Engine
@inject ChallengeLibrary Library
@inject HttpClient Http

<div class="crucible-arena dark-mode">
    @if (Challenges != null && Challenges.Any())
    {
        var current = Challenges[CurrentIndex];
        
        <div class="crucible-header">
            <h1 class="neon-text-blue">The Prompt Crucible</h1>
            <div class="challenge-nav">
                <button @onclick="PrevChallenge" disabled="@(CurrentIndex == 0)">&#9664; Prev</button>
                <span>Challenge @(CurrentIndex + 1) / @Challenges.Count</span>
                <button @onclick="NextChallenge" disabled="@(CurrentIndex == Challenges.Count - 1)">Next &#9654;</button>
            </div>
        </div>

        <div class="crucible-grid">
            <!-- Left: Challenge Telemetry -->
            <div class="panel challenge-panel">
                <h2>@current.Title</h2>
                <div class="badge-row">
                    <span class="badge domain">@current.DomainTag</span>
                    <span class="badge difficulty">@(new string('★', current.DifficultyStars))</span>
                </div>
                <h3>Raw Telemetry Dump</h3>
                <div class="telemetry-box">
                    @current.RawTelemetryDump
                </div>
                <h3>Target Gold Standard</h3>
                <div class="gold-box">
                    @current.ReferenceGoldStandardAnswer
                </div>
            </div>

            <!-- Center: Operator Workspace -->
            <div class="panel operator-panel">
                <h3>Operator Input (Your Prompt)</h3>
                <textarea @bind="UserPrompt" placeholder="Type prompt to process telemetry..."></textarea>
                
                <button class="submit-btn" @onclick="RunLocalEvaluationLoop" disabled="@IsRunning">
                    @(IsRunning ? "Executing AI Pipeline..." : "Run Analysis Pipeline")
                </button>

                @if (!string.IsNullOrEmpty(ActualAiOutput))
                {
                    <h3 style="margin-top:20px; color:var(--neon-amber);">Live AI Completion Result</h3>
                    <div class="gold-box" style="border-left-color: var(--neon-blue);">
                        @ActualAiOutput
                    </div>
                }
            </div>

            <!-- Right: Scoreboard -->
            <div class="panel scoreboard-panel">
                <h3>Evaluation Matrix</h3>
                
                @if (Result != null)
                {
                    <div class="score-summary animate-fade">
                        <h2 class="@GetTierClass(Result.TotalScore)">@Result.OperatorTier</h2>
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: @(AnimationPercentage)%"></div>
                        </div>
                        <p class="cyber-feedback">@Result.TierFeedback</p>
                        
                        @if (AnimationPercentage >= 100)
                        {
                            <button class="download-cert-btn animate-fade" @onclick="DownloadCertificate">
                                Download Competency Certificate
                            </button>
                        }
                        
                        <div class="metric-breakdown">
                            @foreach (var metric in Result.Metrics)
                            {
                                <div class="metric-row">
                                    <span>@metric.CriteriaName</span>
                                    <span>@metric.PointsEarned.ToString("F1") / @metric.MaxPoints</span>
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="terminal-feed">
                    @foreach (var log in ActivePhaseLogs)
                    {
                        <div class="terminal-line">@log</div>
                    }
                    @if (ActivePhaseLogs.Count == 0 && Result == null)
                    {
                        <div class="terminal-line">Awaiting telemetry payload...</div>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="loading-state">Loading Challenge Matrix...</div>
    }
</div>
